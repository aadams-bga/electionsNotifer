# Copy to .env for local development. In Railway, set these as service variables.

DATABASE_URL=postgresql+psycopg://isbe:isbe@localhost:5432/isbe

# Public URL of the web app (used in email links and push payloads)
BASE_URL=http://localhost:8000
SITE_NAME=Illinois Answers Filing Alerts

# Long random string; rotating it invalidates all verify/manage/unsubscribe links
SECRET_KEY=dev-secret-change-me

# Email: "console" logs emails instead of sending; "ses" uses Amazon SES
EMAIL_BACKEND=console
EMAIL_FROM=Illinois Answers Filing Alerts <alerts@example.org>
AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Web push — generate with: python -m isbe_notifier.notify.push genkeys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:alerts@example.org

# Poller
POLL_INTERVAL_SECONDS=90

# Admin page access token (long random string); empty disables /admin
ADMIN_TOKEN=
ADMIN_EMAIL=
